# CSNExplore Environment Configuration
# Copy this file to .env and fill in your actual values

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=local   # Set to "production" on live server

# ── Database (Local) ─────────────────────────────────────────────────────────
DB_HOST_LOCAL=localhost
DB_PORT=3306
DB_NAME_LOCAL=csnexplore
DB_USER_LOCAL=root
DB_PASS_LOCAL=

# ── Database (Production) ────────────────────────────────────────────────────
DB_HOST_PROD=localhost
DB_NAME_PROD=your_prod_db_name
DB_USER_PROD=your_prod_db_user
DB_PASS_PROD=your_prod_db_password

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string

# ── Contact / Branding ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
SUPPORT_EMAIL=support@example.com
CONTACT_PHONE=+91-0000000000

# ── Cloudflare Turnstile ─────────────────────────────────────────────────────
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ── MailerLite ───────────────────────────────────────────────────────────────
MAILERLITE_API_KEY=your_mailerlite_api_key
MAILERLITE_FROM_EMAIL=noreply@example.com
MAILERLITE_FROM_NAME=CSN Explore
ADMIN_NOTIFICATION_EMAIL=support@example.com

# ── SMTP (PHPMailer) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_ENCRYPTION=tls

# ── Google Analytics ─────────────────────────────────────────────────────────
GA4_ID=G-XXXXXXXXXX
