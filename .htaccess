Options -Indexes
RewriteEngine On

# ---- Security: block sensitive directories ----
RewriteRule ^database(/.*)?$ - [F,L]
RewriteRule ^data(/.*)?$ - [F,L]
RewriteRule ^php(/.*)?$ - [F,L]
RewriteRule ^\.env$ - [F,L]
RewriteRule ^composer\.(json|lock)$ - [F,L]

# ---- Route all /api/* requests to PHP backend ----
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^api/(.*)$ php/index.php [L,QSA]

# ---- Serve static files directly if they exist ----
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ---- Root → index.html ----
RewriteRule ^$ public/index.html [L]

# ---- Serve from public/ directory ----
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^(.*)$ public/$1 [L]

# ---- Serve .html files without extension (e.g. /about -> about.html) ----
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI}.html -f
RewriteRule ^(.*)$ public/$1.html [L]

# ---- SPA fallback ----
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.html [L]

# ---- PHP settings for shared hosting ----
php_value upload_max_filesize 20M
php_value post_max_size 20M
php_value max_execution_time 60
php_value memory_limit 128M

# ---- Security headers ----
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"

# ---- Browser Caching ----
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    
    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # HTML and JSON
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType application/json "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    # Cache static assets for 1 year
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Cache HTML and JSON for 1 hour
    <FilesMatch "\.(html|json)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
</IfModule>
